FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

ARG BACKEND_PRIVATE_HOSTPORT=backend:8000
ARG NEXT_PUBLIC_API_BASE_URL=/api

ENV BACKEND_PRIVATE_HOSTPORT=${BACKEND_PRIVATE_HOSTPORT}
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NODE_ENV=production

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start"]
