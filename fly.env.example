POSTGRES_DB=resume_parser
POSTGRES_USER=resume_parser
POSTGRES_PASSWORD=replace-with-managed-db-password

# Use your managed Postgres connection string here.
DATABASE_URL=postgresql+psycopg://resume_parser:replace-with-managed-db-password@your-postgres-host:5432/resume_parser?sslmode=require
ASYNC_DATABASE_URL=postgresql+asyncpg://resume_parser:replace-with-managed-db-password@your-postgres-host:5432/resume_parser?sslmode=require

# Use a free Redis provider such as Upstash.
REDIS_URL=redis://default:replace-with-redis-password@your-redis-host:6379
CELERY_BROKER_URL=redis://default:replace-with-redis-password@your-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://default:replace-with-redis-password@your-redis-host:6379/1

GROQ_API_KEY=replace-with-real-key
GROQ_MODEL=llama-3.3-70b-versatile

BACKEND_CORS_ORIGINS=https://your-frontend-domain
NEXT_PUBLIC_API_BASE_URL=https://resume-parser-backend.fly.dev
